{
    "name": "safety-monitoring-dashboard",
    "version": "1.0.0",
    "scripts": {
        "dev": "concurrently \"npm run sass-dev\" \"npm run serve\"",
        "serve": "http-server . -p 5500 -c-1",
        "sass-dev": "sass scss/main.scss assets/css/style.css --watch",
        "sass-build": "sass scss/main.scss assets/css/style.css --style compressed --no-source-map"
    },
    "devDependencies": {
        "concurrently": "^9.0.1",
        "http-server": "^14.1.1",
        "sass": "1.99.0"
    }
}
